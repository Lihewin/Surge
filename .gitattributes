# Keep local changes to GitHub Actions workflow during fork sync
# Non-workflow conflicts prefer upstream via -X theirs in sync-upstream.yml
# Note: This requires 'git config merge.ours.driver true' to be set in the environment
.github/workflows/main.yml merge=ours
.github/workflows/sync-upstream.yml merge=ours
.github/workflows/dependabot.yml merge=ours
# Upstream-only (SukkaLab dist); also stripped post-merge in sync-upstream.yml
.github/workflows/toggle-dist-repo-visibility.yml merge=ours
